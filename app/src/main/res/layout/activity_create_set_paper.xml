<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#114F98"
    android:clipToPadding="false"
    android:paddingTop="?attr/actionBarSize"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F2F2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Set Paper"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dashboard  /  Create Set Paper Info  /  Create Set Paper Details"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="10dp"
                android:background="#31B6A3" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="16dp">



                <!-- Row 1: board medium class subject -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spBoard"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Spinner
                        android:id="@+id/spMedium"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Spinner
                        android:id="@+id/spClass"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Spinner
                        android:id="@+id/spSubject"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- Row 2: date, marks, paper time, content type -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etDate"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Select Date" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/etMarks"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="Marks"
                        android:inputType="number" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <EditText
                        android:id="@+id/etPaperTime"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:hint="Paper time (Min)"
                        android:inputType="number" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <Spinner
                        android:id="@+id/spContentType"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- Dual list like web -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <!-- All chapter -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All Chapter:"
                            android:textColor="#374151"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvSelectAllLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:padding="4dp"
                            android:text="Select All"
                            android:textColor="#17B890"
                            android:textSize="12sp" />

                        <ListView
                            android:id="@+id/lvAll"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:background="#FFFFFF"
                            android:divider="#E5E7EB"
                            android:dividerHeight="1dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="16dp"
                        android:layout_height="1dp" />

                    <!-- Selected chapter -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Chapter:"
                            android:textColor="#374151"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvDeselectAllRight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:padding="4dp"
                            android:text="Deselect All"
                            android:textColor="#17B890"
                            android:textSize="12sp" />

                        <ListView
                            android:id="@+id/lvSelected"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:background="#FFFFFF"
                            android:divider="#E5E7EB"
                            android:dividerHeight="1dp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProcess"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#17B890"
                    android:text="Data Process"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

