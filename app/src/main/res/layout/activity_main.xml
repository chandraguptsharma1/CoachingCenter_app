<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C9D7E8"
    tools:context=".MainActivity">

    <!-- Center rounded card (blue) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_splash_card"
        android:elevation="10dp"
        android:clipToOutline="true"
        app:layout_constraintWidth_percent="0.78"
        app:layout_constraintDimensionRatio="9:16"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Big faint circle -->
        <View
            android:id="@+id/circle1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_circle_1"
            app:layout_constraintWidth_percent="0.92"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Medium faint circle -->
        <View
            android:id="@+id/circle2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_circle_2"
            app:layout_constraintWidth_percent="0.70"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Inner circle -->
        <View
            android:id="@+id/circle3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_circle_3"
            app:layout_constraintWidth_percent="0.48"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ELA Logo (use your PNG/SVG here) -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_ela_logo"
            android:contentDescription="ELA"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- If you don't have logo image, use this Text fallback (remove ImageView above) -->
        <!--
        <TextView
            android:id="@+id/tvELA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ELA"
            android:textStyle="bold"
            android:textSize="42sp"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>