<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rowRoot"
    android:layout_width="wrap_content"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@android:color/white"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/cbRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:gravity="center"/>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#E5E7EB"/>

    <!-- SR.NO -->
    <TextView
        android:id="@+id/tvSrNo"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- NAME -->
    <TextView
        android:id="@+id/tvName"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.8"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- BATCH -->
    <TextView
        android:id="@+id/tvBatch"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.6"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- BOARD -->
    <TextView
        android:id="@+id/tvBoard"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.6"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- MEDIUM -->
    <TextView
        android:id="@+id/tvMedium"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.6"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- CLASS -->
    <TextView
        android:id="@+id/tvClass"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- CREATED -->
    <TextView
        android:id="@+id/tvCreated"
        style="@style/TableCell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.4"/>

    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E5E7EB"/>

    <!-- ACTION -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="E"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="#F59E0B"/>

        <View android:layout_width="10dp" android:layout_height="1dp"/>

        <TextView
            android:id="@+id/btnDeleteRow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="D"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="#EF4444"/>
    </LinearLayout>

</LinearLayout>