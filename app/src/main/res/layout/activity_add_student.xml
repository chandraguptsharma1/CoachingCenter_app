<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#114F98"
    android:fitsSystemWindows="true"
    android:paddingTop="?attr/actionBarSize">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#33FFFFFF"
        android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:layout_marginBottom="10dp"
        android:padding="16dp">
        <!-- Page Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Info"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#111827"/>

        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/tvBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Dashboard  /  Class Management  /  Add Student"
            android:textSize="12sp"
            android:textColor="#6B7280"/>

        <!-- top green line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="10dp"
            android:background="#31B6A3"/>
    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp">



            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spBoard"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"/>

                <View android:layout_width="12dp" android:layout_height="1dp"/>

                <Spinner
                    android:id="@+id/spMedium"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"/>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Spinner
                    android:id="@+id/spClass"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"/>

                <View android:layout_width="12dp" android:layout_height="1dp"/>

                <Spinner
                    android:id="@+id/spBatch"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"/>
            </LinearLayout>

            <!-- Inputs -->
            <EditText
                android:id="@+id/etStudentName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Student Name"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etParentName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Parent Name"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Address"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Phone"
                android:inputType="phone"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etParentPhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Parent Phone"
                android:inputType="phone"
                android:background="@android:drawable/edit_text"/>

            <EditText
                android:id="@+id/etWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:hint="Whatsapp phone"
                android:inputType="phone"
                android:background="@android:drawable/edit_text"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:text="Submit"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#17B890"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>